      DTS:IncludeInDebugDump="6789"
      DTS:Namespace="User"
      DTS:ObjectName="LastExtractedDate">
      <DTS:VariableValue
        DTS:DataType="7">4/29/1950 6:44:00 PM</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{E0415957-8EAC-4DAE-9645-86909995A153}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;SELECT * FROM dbo.customer_product_ratings WHERE modified_date &gt; '&quot; + &#xA;RIGHT(&quot;0000&quot; + (DT_WSTR,4)YEAR(@[User::LastExtractedDate]),4) + &quot;-&quot; +&#xA;RIGHT(&quot;00&quot; + (DT_WSTR,2)MONTH(@[User::LastExtractedDate]),2) + &quot;-&quot; +&#xA;RIGHT(&quot;00&quot; + (DT_WSTR,2)DAY(@[User::LastExtractedDate]),2) + &quot; &quot; +&#xA;RIGHT(&quot;00&quot; + (DT_WSTR,2)DATEPART(&quot;Hour&quot;, @[User::LastExtractedDate]),2) + &quot;:&quot; +&#xA;RIGHT(&quot;00&quot; + (DT_WSTR,2)DATEPART(&quot;Minute&quot;, @[User::LastExtractedDate]),2) + &quot;:&quot; +&#xA;RIGHT(&quot;00&quot; + (DT_WSTR,2)DATEPART(&quot;Second&quot;, @[User::LastExtractedDate]),2) + &quot;.000'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="selectQuery">
      <DTS:VariableValue
        DTS:DataType="8">SELECT * FROM dbo.customer_product_ratings WHERE modified_date &gt; '1950-04-29 18:44:00.000'</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{A86DD457-84F0-40F7-BCBD-7177FFDC69C0}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;UPDATE dbo.Conf_Table SET last_extract_date = (SELECT ISNULL(MAX(modified_date), '&quot; + &#xA;(DT_WSTR, 50) @[User::LastExtractedDate] + &#xA;&quot;') FROM dbo.customer_product_ratings) WHERE table_name = 'customer_product_ratings';&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="update_config_Table">
      <DTS:VariableValue
        DTS:DataType="8">UPDATE dbo.Conf_Table SET last_extract_date = (SELECT ISNULL(MAX(modified_date), '4/29/1950 6:44:00 PM') FROM dbo.customer_product_ratings) WHERE table_name = 'customer_product_ratings';</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>
